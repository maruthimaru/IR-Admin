# ─────────────────────────────────────────────────────────────
# Platform-Level Settings (required to start the server)
# Company-specific integration keys (Stripe, Twilio, etc.)
# are stored in the database via the Company Settings UI.
# ─────────────────────────────────────────────────────────────

# Django
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.infinitroot.com

# Encryption key for storing sensitive company credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_MAIN_DB=dynamic_admin_main

# Redis (Celery)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# App Domain
BASE_DOMAIN=yourapp.com
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Default from-email (used as fallback if company hasn't set email)
DEFAULT_FROM_EMAIL=noreply@yourapp.com

# ─────────────────────────────────────────────────────────────
# The following are NOT needed here.
# Each company configures their own keys in Company Settings:
#   - Stripe or Razorpay (payment gateway)
#   - Twilio (SMS)
#   - SendGrid / SMTP (email)
# ─────────────────────────────────────────────────────────────
